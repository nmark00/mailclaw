#!/usr/bin/env bash

set -euo pipefail
set -f

usage() {
    cat >&2 <<'EOF'
Usage:
  ./scripts/committer [--force] "commit message" "file" ["file" ...]
EOF
    exit 2
}

if [[ $# -lt 2 ]]; then
    usage
fi

FORCE_DELETE_LOCK=0
if [[ "${1:-}" == "--force" ]]; then
    FORCE_DELETE_LOCK=1
    shift
fi

if [[ $# -lt 2 ]]; then
    usage
fi

COMMIT_MESSAGE="$1"
shift

if [[ "$COMMIT_MESSAGE" != *[![:space:]]* ]]; then
    echo "error: commit message must not be empty" >&2
    exit 1
fi

if [[ -e "$COMMIT_MESSAGE" ]]; then
    echo "error: first argument looks like a path; provide the commit message first" >&2
    exit 1
fi

path_exists_or_tracked() {
    local candidate="$1"
    [[ -e "$candidate" ]] || git ls-files --error-unmatch -- "$candidate" >/dev/null 2>&1
}

append_normalized_path() {
    local raw="$1"

    if path_exists_or_tracked "$raw"; then
        FILES+=("$raw")
        return
    fi

    if [[ "$raw" == *$'\n'* || "$raw" == *$'\r'* ]]; then
        local normalized="${raw//$'\r'/}"
        while IFS= read -r line; do
            if [[ "$line" == *[![:space:]]* ]]; then
                FILES+=("$line")
            fi
        done <<<"$normalized"
        return
    fi

    if [[ "$raw" == *[[:space:]]* ]]; then
        local split_paths=()
        # shellcheck disable=SC2206
        split_paths=($raw)
        if (( ${#split_paths[@]} > 1 )); then
            FILES+=("${split_paths[@]}")
            return
        fi
    fi

    FILES+=("$raw")
}

FILES=()
for raw_arg in "$@"; do
    append_normalized_path "$raw_arg"
done

if (( ${#FILES[@]} == 0 )); then
    usage
fi

for file in "${FILES[@]}"; do
    if [[ "$file" == "." ]]; then
        echo 'error: "." is not allowed; list specific paths instead' >&2
        exit 1
    fi

    case "$file" in
        *node_modules* | */node_modules | */node_modules/* | node_modules)
            echo "error: node_modules paths are not allowed: $file" >&2
            exit 1
            ;;
    esac

    if ! path_exists_or_tracked "$file"; then
        echo "error: file not found: $file" >&2
        exit 1
    fi
done

LAST_GIT_ERROR=""

run_git_command() {
    local stderr_log
    stderr_log="$(mktemp)"

    if "$@" 2>"$stderr_log"; then
        if [[ -s "$stderr_log" ]]; then
            cat "$stderr_log" >&2
        fi
        rm -f "$stderr_log"
        LAST_GIT_ERROR=""
        return 0
    fi

    if [[ -s "$stderr_log" ]]; then
        cat "$stderr_log" >&2
    fi
    LAST_GIT_ERROR="$(cat "$stderr_log")"
    rm -f "$stderr_log"
    return 1
}

is_git_lock_error() {
    printf '%s\n' "$LAST_GIT_ERROR" | grep -Eq \
        "Another git process seems to be running|Unable to create '.*\\.git/[^']+\\.lock'"
}

extract_git_lock_path() {
    printf '%s\n' "$LAST_GIT_ERROR" |
        sed -n "s/.*'\(.*\.git\/[^']*\.lock\)'.*/\1/p" |
        head -n 1
}

run_git_with_lock_retry() {
    local label="$1"
    shift

    local deadline=$((SECONDS + 5))
    local announced_retry=0

    while true; do
        if run_git_command "$@"; then
            return 0
        fi

        if ! is_git_lock_error; then
            return 1
        fi

        if (( SECONDS >= deadline )); then
            break
        fi

        if (( ! announced_retry )); then
            echo "git lock during $label; retrying for up to 5 seconds..." >&2
            announced_retry=1
        fi

        sleep 0.5
    done

    if (( FORCE_DELETE_LOCK )); then
        local lock_path
        lock_path="$(extract_git_lock_path)"
        if [[ -n "$lock_path" && -e "$lock_path" ]]; then
            rm -f "$lock_path"
            echo "removed stale git lock: $lock_path" >&2
            run_git_command "$@"
            return $?
        fi
    fi

    return 1
}

if ! git diff --staged --quiet; then
    echo "error: existing staged changes detected; commit or unstage them before using scripts/committer" >&2
    exit 1
fi

run_git_with_lock_retry "unstaging files" git restore --staged :/
run_git_with_lock_retry "staging files" git add --force -- "${FILES[@]}"

if git diff --staged --quiet; then
    echo "error: no staged changes detected for the selected paths" >&2
    exit 1
fi

run_git_with_lock_retry "commit" git commit -m "$COMMIT_MESSAGE" -- "${FILES[@]}"

echo "Committed \"$COMMIT_MESSAGE\" with ${#FILES[@]} path(s)."
