#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEFAULT_REMOTE="${FRUITMAIL_RELEASE_REMOTE:-origin}"

usage() {
    cat <<'EOF'
Usage:
  ./scripts/release check <version>
  ./scripts/release bump <version>
  ./scripts/release package <version>
  ./scripts/release publish <version>
  ./scripts/release run <version>

Commands:
  check     Validate synced versions and run release test gates.
  bump      Update version files only.
  package   Build and package release artifacts locally.
  publish   Wait for the GitHub release workflow for v<version> and verify it.
  run       Bump, test, package, commit, tag, push, and wait for the workflow.
EOF
}

die() {
    echo "error: $*" >&2
    exit 1
}

require_tool() {
    command -v "$1" >/dev/null 2>&1 || die "missing required tool: $1"
}

require_clean_tree() {
    local status
    status="$(git -C "$ROOT_DIR" status --short)"
    if [[ -n "$status" ]]; then
        echo "$status" >&2
        die "working tree must be clean"
    fi
}

run_actionlint() {
    if command -v actionlint >/dev/null 2>&1; then
        (cd "$ROOT_DIR" && actionlint .github/workflows/*.yml)
    else
        echo "actionlint not installed; skipping workflow lint."
    fi
}

bump_version() {
    "$ROOT_DIR/scripts/sync-version.sh" "$1"
}

run_checks() {
    local version="$1"

    "$ROOT_DIR/scripts/sync-version.sh" --check "$version"
    run_actionlint

    (
        cd "$ROOT_DIR"
        rm -f tests/test.db
        npm test
        npm run build
    )
}

package_release() {
    (
        cd "$ROOT_DIR"
        "$ROOT_DIR/scripts/package-release.sh"
    )
}

commit_tag_and_push() {
    local version="$1"
    local tag="v$version"
    local branch

    (
        cd "$ROOT_DIR"
        branch="$(git branch --show-current)"
        [[ -n "$branch" ]] || die "cannot release from detached HEAD"
        git add package.json package-lock.json
        git commit -m "Bump version to $version"
        git tag -a "$tag" -m "$tag"
        git push "$DEFAULT_REMOTE" "HEAD:refs/heads/$branch"
        git push "$DEFAULT_REMOTE" "$tag"
    )
}

wait_for_release_run() {
    local tag="$1"
    local run_id=""

    for _ in {1..20}; do
        run_id="$(cd "$ROOT_DIR" && gh run list \
            --workflow release.yml \
            --branch "$tag" \
            --event push \
            --json databaseId \
            --jq '.[0].databaseId // empty' \
            --limit 1)"
        if [[ -n "$run_id" ]]; then
            break
        fi
        sleep 3
    done

    [[ -n "$run_id" ]] || die "could not find GitHub Actions release run for $tag"

    (
        cd "$ROOT_DIR"
        gh run watch "$run_id" --exit-status
    )
}

publish_release() {
    local version="$1"
    local tag="v$version"

    require_tool gh
    (
        cd "$ROOT_DIR"
        gh auth status >/dev/null
    )

    wait_for_release_run "$tag"

    (
        cd "$ROOT_DIR"
        gh release edit "$tag" --draft=false >/dev/null
    )
    echo "Release $tag workflow finished and is published."
}

MODE="${1:-}"
[[ -n "$MODE" ]] || {
    usage >&2
    exit 2
}
shift

VERSION=""

case "$MODE" in
    check | bump | package)
        [[ $# -eq 1 ]] || {
            usage >&2
            exit 2
        }
        VERSION="$1"
        ;;
    publish | run)
        [[ $# -eq 1 ]] || {
            usage >&2
            exit 2
        }
        VERSION="$1"
        ;;
    *)
        usage >&2
        exit 2
        ;;
esac

case "$MODE" in
    check)
        run_checks "$VERSION"
        ;;
    bump)
        require_clean_tree
        bump_version "$VERSION"
        ;;
    package)
        run_checks "$VERSION"
        package_release
        ;;
    publish)
        publish_release "$VERSION"
        ;;
    run)
        require_clean_tree
        require_tool gh
        bump_version "$VERSION"
        run_checks "$VERSION"
        package_release
        commit_tag_and_push "$VERSION"
        publish_release "$VERSION"
        ;;
esac
